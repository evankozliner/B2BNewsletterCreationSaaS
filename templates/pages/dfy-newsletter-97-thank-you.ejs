<!-- UTM Parameter Preservation -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const trackingParams = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'ref'];

    const filteredParams = new URLSearchParams();
    trackingParams.forEach(param => {
      if (urlParams.has(param)) {
        filteredParams.set(param, urlParams.get(param));
      }
    });
  });
</script>

<!-- Calendly Event Tracking -->
<script>
  window.addEventListener('message', function(e) {
    if (e.data.event && e.data.event.indexOf('calendly') === 0) {
      if (e.data.event === 'calendly.event_scheduled') {
        // Fire Meta Pixel Lead event if available
        if (typeof fbq !== 'undefined') {
          var storedFbclid = sessionStorage.getItem('_fbclid');
          var eventData = {};
          if (storedFbclid) {
            eventData.external_id = storedFbclid;
          }
          fbq('track', 'Lead', eventData, {
            client_user_agent: navigator.userAgent
          });
          console.log('Meta Pixel Lead event fired');
        }
      }
    }
  });
</script>
